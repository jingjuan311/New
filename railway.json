{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": [
            "python311",
            "glibc",
            "glib",
            "nss",
            "nspr",
            "atk",
            "cups",
            "dbus",
            "expat",
            "libdrm",
            "libxkbcommon",
            "mesa",
            "xorg.libX11",
            "xorg.libXcomposite",
            "xorg.libXdamage",
            "xorg.libXext",
            "xorg.libXfixes",
            "xorg.libXrandr",
            "xorg.libxcb",
            "xorg.libXrender",
            "xorg.libXtst",
            "pango",
            "cairo"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "playwright install chromium && python bot.py"
  }
}